{
  "dashboard": {
    "title": "Rain Prediction MLOps Dashboard",
    "tags": ["mlops", "fastapi", "rain-prediction"],
    "timezone": "browser",
    "panels": [
      {
        "title": "Top 15 Cities by Predictions",
        "type": "barchart",
        "gridPos": {"h": 10, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "topk(15, sum(rain_predictions_total) by (location))",
            "legendFormat": "{{location}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "palette-classic"}
          }
        },
        "options": {
          "orientation": "horizontal",
          "xAxis": {
            "label": "Number of Predictions",
            "show": true
          },
          "yAxis": {
            "label": "City",
            "show": true
          }
        }
      },
      {
        "title": "Confidence Distribution (10% Steps)",
        "type": "histogram",
        "gridPos": {"h": 10, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "sum(rate(rain_prediction_confidence_bucket[5m])) by (le)",
            "legendFormat": "{{le}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "min": 0,
            "max": 1
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "+Inf"
              },
              "properties": [
                {
                  "id": "custom.hideFrom",
                  "value": {
                    "tooltip": true,
                    "viz": true,
                    "legend": true
                  }
                }
              ]
            }
          ]
        },
        "options": {
          "bucketSize": 0.1,
          "barGap": 0.05,
          "barWidth": 0.9,
          "xAxis": {
            "min": 0,
            "max": 1,
            "step": 0.1,
            "label": "Confidence Score"
          },
          "yAxis": {
            "label": "Number of Predictions",
            "show": true
          }
        }
      },
      {
        "title": "Requests per Endpoint",
        "type": "barchart",
        "gridPos": {"h": 10, "w": 12, "x": 0, "y": 10},
        "targets": [
          {
            "expr": "sum(rate(http_requests_total[5m])) by (handler)",
            "legendFormat": "{{handler}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "palette-classic"}
          }
        },
        "options": {
          "orientation": "vertical",
          "xAxis": {
            "label": "Endpoint",
            "show": true
          },
          "yAxis": {
            "label": "Number of Requests",
            "show": true
          }
        }
      },
      {
        "title": "Total Predictions",
        "type": "stat",
        "gridPos": {"h": 10, "w": 12, "x": 12, "y": 10},
        "targets": [
          {
            "expr": "sum(rain_predictions_total)",
            "legendFormat": "Total Predictions",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "blue", "value": null}
              ]
            },
            "text": {
              "fontSize": 48
            }
          }
        },
        "options": {
          "textMode": "value_and_name",
          "colorMode": "background",
          "graphMode": "none",
          "justifyMode": "center"
        }
      },
      {
        "title": "Rain Prediction Map - Australia",
        "type": "geomap",
        "gridPos": {"h": 14, "w": 24, "x": 0, "y": 20},
        "targets": [
          {
            "expr": "avg(rain_predictions_total) by (location)",
            "legendFormat": "{{location}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null, "text": "No Rain"},
                {"color": "red", "value": 0.5, "text": "Rain"}
              ]
            }
          }
        },
        "options": {
          "view": {
            "id": "australia",
            "lat": -25,
            "lon": 134,
            "zoom": 4
          },
          "controls": {
            "showZoom": true,
            "showAttribution": true,
            "showScale": true
          },
          "layers": [
            {
              "type": "markers",
              "name": "Predictions",
              "id": "prediction-markers",
              "source": {
                "type": "query",
                "query": "avg(rain_predictions_total) by (location)",
                "fields": [
                  {
                    "name": "location",
                    "type": "string",
                    "values": [
                      "Albury", "Sydney", "Melbourne", "Brisbane", "Perth",
                      "Adelaide", "Canberra", "Hobart", "Darwin", "Cairns",
                      "Townsville", "Newcastle", "Wollongong", "Geelong", "Launceston"
                    ]
                  },
                  {
                    "name": "lat",
                    "type": "number",
                    "values": [
                      -36.07, -33.86, -37.81, -27.47, -31.95,
                      -34.92, -35.28, -42.87, -12.46, -16.92,
                      -19.25, -32.92, -34.42, -38.14, -41.43
                    ]
                  },
                  {
                    "name": "lng",
                    "type": "number",
                    "values": [
                      146.90, 151.20, 144.96, 153.02, 115.86,
                      138.60, 149.12, 147.32, 130.84, 145.77,
                      146.80, 151.78, 150.89, 144.36, 147.13
                    ]
                  }
                ]
              },
              "markerSize": 15,
              "markerColor": {
                "mode": "fixed",
                "color": "blue"
              },
              "showLegend": true
            }
          ]
        }
      }
    ],
    "schemaVersion": 16,
    "version": 0
  },
  "overwrite": false
}