{
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "Current RMSE",
      "id": 1,
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "last_over_time(model_rmse_score[24h])",
          "legendFormat": "RMSE",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.25, "color": "orange" },
              { "value": 0.45, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Current MAE",
      "id": 2,
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "last_over_time(model_mae_score[24h])",
          "legendFormat": "MAE",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.20, "color": "orange" },
              { "value": 0.35, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Current R² Score",
      "id": 3,
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "last_over_time(model_r2_score[24h])",
          "legendFormat": "R²",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 0.5, "color": "orange" },
              { "value": 0.8, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "type": "state-timeline",
      "title": "Daily Metric Batch Status",
      "id": 4,
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "absent(last_over_time(model_rmse_score[24h])) == 1 or abs(last_over_time(model_rmse_score[24h])) >= 0",
          "legendFormat": "Pipeline",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 0,
            "fillOpacity": 70
          },
          "mappings": [
            { "type": "special", "options": { "match": "null", "result": { "text": "WAITING FOR AIRFLOW", "color": "orange" } } },
            { "type": "range", "options": { "from": 0, "to": 999, "result": { "text": "PIPELINE ACTIVE", "color": "green" } } }
          ]
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Model Error Metrics Over Time (RMSE & MAE)",
      "id": 5,
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "last_over_time(model_rmse_score[24h])",
          "legendFormat": "RMSE",
          "datasource": "Prometheus"
        },
        {
          "expr": "last_over_time(model_mae_score[24h])",
          "legendFormat": "MAE",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Model Fit Over Time (R² Score)",
      "id": 6,
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "last_over_time(model_r2_score[24h])",
          "legendFormat": "R² Score",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" }
        }
      }
    },
    {
      "type": "stat",
      "title": "Current Drift Status",
      "id": 7,
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "last_over_time(rain_dataset_drift_detected[24h])",
          "legendFormat": "Drift",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "No Drift", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "DRIFT DETECTED", "color": "red" } } }
          ],
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "type": "state-timeline",
      "title": "Data Drift Detected Over Time",
      "id": 8,
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "last_over_time(rain_dataset_drift_detected[24h])",
          "legendFormat": "Drift Status",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 0,
            "fillOpacity": 70
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "No Drift", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "DRIFT DETECTED", "color": "red" } } }
          ]
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "title": "Model Performance & Drift",
  "time": { "from": "now-7d", "to": "now" }
}