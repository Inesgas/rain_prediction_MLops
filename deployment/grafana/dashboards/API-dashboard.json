{
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "timeseries",
      "title": "API Request Rate",
      "id": 1,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_highr_seconds_count[1m])) by (handler)",
          "legendFormat": "{{handler}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" },
          "unit": "reqps"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "API Latency (P95 Perzentil)",
      "id": 2,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_highr_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95 Latency",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line" },
          "unit": "s"
        }
      }
    },
    {
      "type": "piechart",
      "title": "Rain Predictions Distribution",
      "id": 4,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rain_predictions_total) by (rain_tomorrow)",
          "legendFormat": "Rain Tomorrow: {{rain_tomorrow}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Model Inference Duration (P99 Perzentil)",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_highr_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99 Inference Time",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" },
          "unit": "s"
        }
      }
    },
    {
      "type": "gauge",
      "title": "HTTP 5xx Error Rate",
      "id": 3,
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_highr_seconds_count{status=~\"5..\"}[5m])) or vector(0)",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 10,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.1, "color": "red" }
            ]
          }
        }
      }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
  "title": "Rain Prediction MLOps Performance",
  "time": { "from": "now-15m", "to": "now" }
}
