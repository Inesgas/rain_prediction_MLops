# Each developer must set this to their own host user ID before first run:
#   echo "AIRFLOW_UID=$(id -u)" >> .env
# This makes the Airflow container write files as YOUR user instead of a
# hardcoded UID 50000, so you never need `sudo chown` to fix permissions
# on data/, models/, .dvc/, etc. after running Airflow tasks.
# Leave empty here — do NOT commit a real UID, it differs per machine.
AIRFLOW_UID=


# Local host access to the Docker Compose MLflow UI.
MLFLOW_TRACKING_URI=https://dagshub.com/Inesgas/rain_prediction_MLops.mlflow

# Airflow runs inside Docker Compose, so it reaches MLflow by service name.
AIRFLOW_MLFLOW_TRACKING_URI=http://mlflow:5000

MLFLOW_EXPERIMENT_NAME=rain_prediction_winner
MLFLOW_REGISTERED_MODEL_NAME=rain_prediction_final_winner
MLFLOW_REGISTER_MODEL=true

# Runs data_model_versioning daily at 04:00 UTC. Set to empty to make it manual.
MODEL_VERSIONING_SCHEDULE=0 4 * * *

# Optional when pointing Airflow or local scripts at DagsHub MLflow:
# MLFLOW_TRACKING_URI=https://dagshub.com/Inesgas/rain_prediction_MLops.mlflow
# MLFLOW_TRACKING_USERNAME=<dagshub username>
# MLFLOW_TRACKING_PASSWORD=<dagshub personal token>
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=

